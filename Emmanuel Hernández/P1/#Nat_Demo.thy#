theory Nat_Demo
imports Main
begin

term "Suc"

datatype N = cero | suc N

thm N.inject
thm N.distinct
thm N.induct

fun suma:: "N\<Rightarrow>N\<Rightarrow>N" where
"suma cero y = y" |
"suma (suc x) y = suc (suma x y)"

lemma "suma x y = suma y x"
proof -
  have L1: "\<And>y x. suma y (suc x) = suc (suma y x)"
  by (induct_tac y, auto)
  lemma L2: "\<And>y. suma y cero = y"
  by (induct_tac y, auto)
  show ?thesis
by (induct_tac x, auto simp add: L1 L2)
qed

thm suma.simps
thm suma.induct

lemma "suma y cero = y"
  apply (induction y)
   apply (auto)
  done

lemma "suma x (suc y) = suc(suma x y)"
  apply (induction x)
  by auto


end